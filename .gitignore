# Dependencies
node_modules/
**/node_modules/

# Environment variables (contains secrets)
backend/.env
**/.env
.env.local
.env.*.local

# Database (runtime data with user info)
database/*
!database/.gitkeep

# Uploaded videos & HLS streams (large binary files)
videos/*
!videos/.gitkeep

# Build output
dist/
build/
**/dist/
**/build/

# Release packages
release/

# IDE & Editor
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime & temp files
*.tmp
*.temp
